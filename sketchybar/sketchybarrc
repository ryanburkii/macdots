#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# shellcheck source=/dev/null
source "$CONFIG_DIR/colors.sh"

##### Bar Appearance #####
sketchybar --bar \
  position=top \
  height=33 \
  color=$BAR_COLOR \
  blur_radius=0 \
  shadow=off \
  padding_left=8 \
  padding_right=8 \
  corner_radius=10

##### Defaults #####
sketchybar --default \
  icon.font="Hack Nerd Font:Regular:13.0" \
  label.font="Hack Nerd Font:Regular:12.0" \
  icon.color=$FG_COLOR \
  label.color=$FG_COLOR \
  padding_left=0 \
  padding_right=0 \
  icon.padding_left=7 \
  icon.padding_right=7 \
  label.padding_left=0 \
  label.padding_right=7

##### Left: Apple logo #####
# U+F179 nf-fa-apple — in Hack Nerd Font; use printf for bash 3.2 compatibility
APPLE_ICON=$(printf '\xef\x85\xb9')
sketchybar --add item apple left \
  --set apple \
  icon="$APPLE_ICON" \
  label.drawing=off \
  click_script="open '/System/Applications/System Settings.app'"

##### Left: Spaces 1–5 #####
for i in 1 2 3 4 5; do
  sketchybar --add space space.$i left \
    --set space.$i \
    space=$i \
    icon="$i" \
    icon.padding_left=6 \
    icon.padding_right=6 \
    label.drawing=off \
    icon.color=$FG_DIM \
    icon.highlight_color=$ACCENT \
    script="$PLUGIN_DIR/space.sh" \
    click_script="open -a 'Mission Control'"
done

##### Right: Clock (moved from center — avoids notch) #####
sketchybar --add item clock right \
  --set clock \
  update_freq=10 \
  icon.drawing=off \
  label.padding_left=0 \
  label.padding_right=18 \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  popup.align=right \
  popup.height=22 \
  click_script="open -a Calendar" \
  script="$PLUGIN_DIR/clock.sh" \
  --subscribe clock mouse.entered mouse.exited

sketchybar --add item clock.cal_header popup.clock \
  --set clock.cal_header \
  icon.drawing=off \
  width=182 \
  label.font="Hack Nerd Font:Regular:13.0" \
  label.color=$ACCENT \
  label.align=center \
  label.padding_left=12 \
  label.padding_right=12

sketchybar --add item clock.cal_days popup.clock \
  --set clock.cal_days \
  icon.drawing=off \
  width=182 \
  label.font="Hack Nerd Font:Regular:12.0" \
  label.color=$FG_DIM \
  label.padding_left=12 \
  label.padding_right=12

for i in 1 2 3 4 5 6; do
  sketchybar --add item "clock.cal_w${i}" popup.clock \
    --set "clock.cal_w${i}" \
    icon.drawing=off \
    width=182 \
    label.font="Hack Nerd Font:Regular:12.0" \
    label.padding_left=12 \
    label.padding_right=12
done

##### Right: Theme Picker #####
PALETTE_ICON=$(printf '\xef\x87\xbc')  # nf-fa-paint_brush
CHECK_ICON=$(printf '\xef\x80\x8c')    # nf-fa-check
sketchybar --add item theme right \
  --set theme \
  icon="$PALETTE_ICON" \
  label.drawing=off \
  icon.color=$ACCENT \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  popup.align=right \
  popup.height=22 \
  click_script="$PLUGIN_DIR/theme.sh toggle"

for THEME_NAME in nord rosepine catppuccin gruvbox-dark gruvbox-light; do
  sketchybar --add item "theme.$THEME_NAME" popup.theme \
    --set "theme.$THEME_NAME" \
    icon="$CHECK_ICON" \
    icon.drawing=off \
    icon.color=$ACCENT \
    icon.padding_left=4 \
    icon.padding_right=0 \
    width=170 \
    label="$THEME_NAME" \
    label.padding_left=6 \
    label.padding_right=12 \
    click_script="$PLUGIN_DIR/theme.sh pick $THEME_NAME"
done

##### Right: Bluetooth #####
sketchybar --add item bluetooth right \
  --set bluetooth \
  update_freq=10 \
  label.drawing=off \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  click_script="open 'x-apple.systempreferences:com.apple.preferences.Bluetooth'" \
  script="$PLUGIN_DIR/bluetooth.sh" \
  --subscribe bluetooth mouse.entered mouse.exited \
  --add item bluetooth.detail popup.bluetooth \
  --set bluetooth.detail \
  icon.drawing=off \
  label.padding_left=8 \
  label.padding_right=8

##### Right: WiFi #####
sketchybar --add item wifi right \
  --set wifi \
  update_freq=5 \
  label.drawing=off \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  click_script="open 'x-apple.systempreferences:com.apple.wifi-settings-extension'" \
  script="$PLUGIN_DIR/wifi.sh" \
  --subscribe wifi wifi_change mouse.entered mouse.exited \
  --add item wifi.detail popup.wifi \
  --set wifi.detail \
  icon.drawing=off \
  label.padding_left=8 \
  label.padding_right=8

##### Right: Volume #####
sketchybar --add item volume right \
  --set volume \
  label.drawing=off \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  click_script="open 'x-apple.systempreferences:com.apple.preference.sound'" \
  script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change mouse.entered mouse.exited \
  --add item volume.detail popup.volume \
  --set volume.detail \
  icon.drawing=off \
  label.padding_left=8 \
  label.padding_right=8

##### Right: CPU #####
sketchybar --add item cpu right \
  --set cpu \
  update_freq=5 \
  label.drawing=off \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  click_script="open -na Ghostty.app --args -e btop" \
  script="$PLUGIN_DIR/cpu.sh" \
  --subscribe cpu mouse.entered mouse.exited \
  --add item cpu.detail popup.cpu \
  --set cpu.detail \
  icon.drawing=off \
  label.padding_left=8 \
  label.padding_right=8

##### Right: Battery #####
sketchybar --add item battery right \
  --set battery \
  update_freq=60 \
  label.drawing=off \
  popup.background.color=$POPUP_BG \
  popup.background.border_width=1 \
  popup.background.border_color=$POPUP_BORDER \
  popup.background.corner_radius=6 \
  popup.y_offset=5 \
  click_script="open 'x-apple.systempreferences:com.apple.preference.battery'" \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change mouse.entered mouse.exited \
  --add item battery.detail popup.battery \
  --set battery.detail \
  icon.drawing=off \
  label.padding_left=8 \
  label.padding_right=8

##### Right: Tailscale #####
sketchybar --add item tailscale right \
  --set tailscale \
  update_freq=10 \
  script="$HOME/.config/sketchybar/plugins/tailscale.sh" \
  click_script="open -a Tailscale" \
  icon.font="JetBrainsMono Nerd Font:Regular:16.0" \
  icon.color=$TAILSCALE_COLOR \
  icon.padding_left=6 \
  icon.padding_right=6 \
  label.drawing=off \
  drawing=off \
  --subscribe tailscale system_woke

##### Force all scripts to run initially #####
sketchybar --update
